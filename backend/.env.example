NODE_ENV=development
PORT=5001
FRONTEND_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/wam_crm_ai
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

BCRYPT_ROUNDS=12
JWT_ACCESS_SECRET=replace-with-at-least-32-characters-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_BYTES=64
REFRESH_TOKEN_TTL_DAYS=30

# Field-level encryption
ENCRYPTION_KEY_CURRENT_VERSION=1
ENCRYPTION_KEY_V1=

SEED_ORGANIZATION_NAME=Vistaar Media
SEED_ORGANIZATION_SLUG=vistaar-media
SEED_SUPER_ADMIN_NAME=Vistaar Super Admin
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-minimum-12-character-password

# WhatsApp provider controls
WHATSAPP_PROVIDER=baileys
WHATSAPP_ENABLED=false
WHATSAPP_POC_ACCOUNT_ID=
WHATSAPP_QR_OUTPUT=terminal

# Phase 5 safety
WHATSAPP_ALLOW_DISPOSABLE_POC_ONLY=true
WHATSAPP_SEND_TEXT_POC_ENABLED=false
WHATSAPP_MAX_OUTBOUND_PER_MINUTE=5
